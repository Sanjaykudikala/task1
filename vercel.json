{
  "version": 2,
  "builds": [
    {
      "src": "ai-product-app/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/recommend",
      "destination": "backend/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "ai-product-app/$1"
    }
  ]
}
